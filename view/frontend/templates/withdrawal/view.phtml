<?php
/** @var \Zwernemann\Withdrawal\Block\Withdrawal\View $block */
$order = $block->getOrder();
$withdrawnItemIds = $block->getWithdrawnOrderItemIds();
$partialAllowed = $block->isPartialWithdrawalAllowed();
?>
<?php if ($order): ?>
<div class="withdrawal-view-container">
    <div class="block block-order-details-view">
        <div class="block-title">
            <strong><?= $block->escapeHtml(__('Withdrawal for Order #%1', $order->getIncrementId())) ?></strong>
        </div>
        <div class="block-content">
            <div class="box box-order-details">
                <table class="table table-order-details" id="withdrawal-order-details">
                    <tbody>
                        <tr>
                            <th scope="row"><?= $block->escapeHtml(__('Order Number')) ?></th>
                            <td>#<?= $block->escapeHtml($order->getIncrementId()) ?></td>
                        </tr>
                        <tr>
                            <th scope="row"><?= $block->escapeHtml(__('Order Date')) ?></th>
                            <td><?= $block->escapeHtml($block->getFormattedDate($order->getCreatedAt())) ?></td>
                        </tr>
                        <tr>
                            <th scope="row"><?= $block->escapeHtml(__('Order Status')) ?></th>
                            <td><?= $block->escapeHtml($order->getStatusLabel()) ?></td>
                        </tr>
                        <tr>
                            <th scope="row"><?= $block->escapeHtml(__('Order Total')) ?></th>
                            <td><?= /* @noEscape */ $order->formatPrice($order->getGrandTotal()) ?></td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <?php if ($block->hasPartialWithdrawal()): ?>
            <div class="message notice withdrawal-partial-notice">
                <span><?= $block->escapeHtml(__('Some items from this order have already been withdrawn. The items marked below are no longer available for withdrawal.')) ?></span>
            </div>
            <?php endif; ?>

            <div class="withdrawal-info-box">
                <?php if ($block->hasExistingWithdrawal()): ?>
                    <div class="message info">
                        <span><?= $block->escapeHtml(__('All items of this order have already been withdrawn.')) ?></span>
                    </div>
                <?php elseif ($block->isWithdrawalAllowed()): ?>
                    <?php $deadline = $block->getWithdrawalDeadline(); ?>
                    <div class="withdrawal-deadline">
                        <?php if ($deadline !== ''): ?>
                        <p>
                            <strong><?= $block->escapeHtml(__('Withdrawal deadline:')) ?></strong>
                            <?= $block->escapeHtml($deadline) ?>
                        </p>
                        <?php else: ?>
                        <p><?= $block->escapeHtml(__('This order has not been shipped yet. You may withdraw at any time until you receive the goods.')) ?></p>
                        <?php endif; ?>
                        <?php if ($partialAllowed): ?>
                        <p><?= $block->escapeHtml(__('Select the items you wish to withdraw. You may withdraw individual items (partial withdrawal) or all items at once.')) ?></p>
                        <?php else: ?>
                        <p><?= $block->escapeHtml(__('By submitting the withdrawal, you declare that you wish to revoke the purchase contract for this order.')) ?></p>
                        <?php endif; ?>
                    </div>

                    <form method="post" action="<?= $block->escapeUrl($block->getSubmitUrl()) ?>" id="withdrawal-form">
                        <?= /* @noEscape */ $block->getBlockHtml('formkey') ?>
                        <input type="hidden" name="order_id" value="<?= (int) $order->getEntityId() ?>"/>
                        <?php if ($block->isGuest()): ?>
                            <input type="hidden" name="guest" value="1"/>
                            <input type="hidden" name="guest_email" value="<?= $block->escapeHtmlAttr($block->getGuestEmail()) ?>"/>
                        <?php endif; ?>

                        <div class="box box-order-items">
                            <strong class="box-title">
                                <span><?= $block->escapeHtml(__('Select Items to Withdraw')) ?></span>
                            </strong>
                            <table class="table table-order-items" id="withdrawal-order-items">
                                <thead>
                                    <tr>
                                        <?php if ($partialAllowed): ?>
                                        <th class="col col-withdrawal-select">
                                            <input type="checkbox" id="withdrawal-select-all" title="<?= $block->escapeHtmlAttr(__('Select All')) ?>" checked/>
                                        </th>
                                        <?php endif; ?>
                                        <th class="col name"><?= $block->escapeHtml(__('Product Name')) ?></th>
                                        <th class="col sku"><?= $block->escapeHtml(__('SKU')) ?></th>
                                        <th class="col qty"><?= $block->escapeHtml(__('Qty Ordered')) ?></th>
                                        <?php if ($partialAllowed): ?>
                                        <th class="col qty-withdraw"><?= $block->escapeHtml(__('Qty to Withdraw')) ?></th>
                                        <?php endif; ?>
                                        <th class="col price"><?= $block->escapeHtml(__('Price')) ?></th>
                                        <th class="col subtotal"><?= $block->escapeHtml(__('Subtotal')) ?></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <?php foreach ($order->getAllVisibleItems() as $item): ?>
                                    <?php
                                    $itemId = (int) $item->getItemId();
                                    $isWithdrawn = in_array($itemId, $withdrawnItemIds, true);
                                    $qtyOrdered = (int) $item->getQtyOrdered();
                                    ?>
                                    <tr class="<?= $isWithdrawn ? 'withdrawal-item-disabled withdrawal-item-withdrawn' : 'withdrawal-item-selectable' ?>">
                                        <?php if ($partialAllowed): ?>
                                        <td class="col col-withdrawal-select">
                                            <?php if ($isWithdrawn): ?>
                                                <span class="withdrawal-status-badge">
                                                    <?= $block->escapeHtml(__('Withdrawn')) ?>
                                                </span>
                                            <?php else: ?>
                                                <input type="checkbox"
                                                       name="selected_items[]"
                                                       value="<?= $itemId ?>"
                                                       class="withdrawal-item-checkbox"
                                                       checked/>
                                            <?php endif; ?>
                                        </td>
                                        <?php elseif (!$isWithdrawn): ?>
                                            <input type="hidden" name="selected_items[]" value="<?= $itemId ?>"/>
                                        <?php endif; ?>
                                        <td class="col name" data-th="<?= $block->escapeHtmlAttr(__('Product Name')) ?>">
                                            <?= $block->escapeHtml($item->getName()) ?>
                                        </td>
                                        <td class="col sku" data-th="<?= $block->escapeHtmlAttr(__('SKU')) ?>">
                                            <?= $block->escapeHtml($item->getSku()) ?>
                                        </td>
                                        <td class="col qty" data-th="<?= $block->escapeHtmlAttr(__('Qty Ordered')) ?>">
                                            <?= $qtyOrdered ?>
                                        </td>
                                        <?php if ($partialAllowed): ?>
                                        <td class="col qty-withdraw" data-th="<?= $block->escapeHtmlAttr(__('Qty to Withdraw')) ?>">
                                            <?php if (!$isWithdrawn): ?>
                                                <input type="number"
                                                       name="item_qty[<?= $itemId ?>]"
                                                       value="<?= $qtyOrdered ?>"
                                                       min="1"
                                                       max="<?= $qtyOrdered ?>"
                                                       class="input-text withdrawal-qty-input"
                                                       data-item-id="<?= $itemId ?>"/>
                                            <?php else: ?>
                                                &mdash;
                                            <?php endif; ?>
                                        </td>
                                        <?php endif; ?>
                                        <td class="col price" data-th="<?= $block->escapeHtmlAttr(__('Price')) ?>">
                                            <?= /* @noEscape */ $order->formatPrice($item->getPriceInclTax()) ?>
                                        </td>
                                        <td class="col subtotal" data-th="<?= $block->escapeHtmlAttr(__('Subtotal')) ?>">
                                            <?= /* @noEscape */ $order->formatPrice($item->getRowTotalInclTax()) ?>
                                        </td>
                                    </tr>
                                    <?php endforeach; ?>
                                </tbody>
                            </table>
                        </div>

                        <div class="actions-toolbar">
                            <div class="primary">
                                <button type="submit" class="action primary withdraw"
                                        title="<?= $block->escapeHtmlAttr(__('Submit Withdrawal')) ?>"
                                        id="withdrawal-submit-btn">
                                    <span><?= $block->escapeHtml(__('Submit Withdrawal')) ?></span>
                                </button>
                            </div>
                            <div class="secondary">
                                <a href="<?= $block->escapeUrl($block->getUrl('sales/order/history')) ?>"
                                   class="action back">
                                    <span><?= $block->escapeHtml(__('Back')) ?></span>
                                </a>
                            </div>
                        </div>
                    </form>
                    <script type="text/x-magento-init">
                        {
                            "#withdrawal-form": {
                                "Zwernemann_Withdrawal/js/withdrawal-confirm": {}
                            }
                        }
                    </script>
                    <?php if ($partialAllowed): ?>
                    <script type="text/x-magento-init">
                        {
                            "#withdrawal-select-all": {
                                "Zwernemann_Withdrawal/js/withdrawal-select-all": {}
                            }
                        }
                    </script>
                    <?php endif; ?>
                <?php else: ?>
                    <div class="message warning">
                        <span><?= $block->escapeHtml(__('The withdrawal period for this order has expired. The deadline was: %1', $block->getWithdrawalDeadline())) ?></span>
                    </div>
                <?php endif; ?>
            </div>
        </div>
    </div>
</div>
<?php else: ?>
<div class="message info">
    <span><?= $block->escapeHtml(__('The order could not be found.')) ?></span>
</div>
<?php endif; ?>
